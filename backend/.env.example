# =============================================================================
# World Cup Prediction Market — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- Server ---
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# --- TxLINE API (TxODDS Devnet) ---
# Base URL for the TxLINE devnet API
TXLINE_API_BASE=https://txline-dev.txodds.com/api
# JWT obtained from POST /auth/guest/start (mock in dev)
TXLINE_JWT=mock-jwt-for-development
# API token from on-chain subscription activation (mock in dev)
TXLINE_API_TOKEN=mock-api-token-for-development

# --- SQLite ---
# Path to the SQLite database file (relative to project root)
DATABASE_PATH=./data/worldcup.db

# --- Solana ---
# RPC endpoint (mainnet-beta or devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com
# Keeper bot's private key (base58) for settlement transactions
SOLANA_KEEPER_PRIVATE_KEY=
# The deployed prediction market program ID on Solana
SOLANA_PROGRAM_ID=

# --- Logging ---
LOG_LEVEL=info

# --- WebSocket ---
# Heartbeat interval in ms
WS_HEARTBEAT_INTERVAL=30000

# --- Market Scheduling ---
# How often (ms) to check for fixture updates
FIXTURE_POLL_INTERVAL=60000
# How far ahead (ms) to look for fixtures to create markets
MARKET_CREATION_LOOKAHEAD=604800000
