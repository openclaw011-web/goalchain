# =============================================================================
# GoalChain Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and adjust for your environment.
#   cp .env.example .env.local
# =============================================================================

# Backend REST API base URL (include /api suffix)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Backend WebSocket relay URL
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Solana RPC endpoint
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# Deployed prediction-market program ID (Devnet)
NEXT_PUBLIC_PREDICTION_PROGRAM_ID=C5vNdxLcaMriywhQJzv3Dv8PKDfkfnKWHvqCVnqgEQE5
